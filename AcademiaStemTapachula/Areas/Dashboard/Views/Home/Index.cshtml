
@section Styles {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700&family=Roboto:wght@300;400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css">
    
    <style>
        :root {
            --robot-blue: #00d2ff;
            --robot-dark-bg: #0f172a;
            --robot-card-bg: #1e293b;
            --robot-accent: #f43f5e;
            --text-main: #f8fafc;
            --text-dim: #94a3b8;
            --sidebar-width: 250px;
        }

        body {
            background-color: var(--robot-dark-bg);
            font-family: 'Roboto', sans-serif;
            color: var(--text-main);
            overflow-x: hidden;
        }

        /* Estilos de Tarjetas del Dashboard */
        .stat-card {
            background: var(--robot-card-bg);
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: 12px;
            padding: 1.5rem;
            transition: transform 0.3s ease;
        }

            .stat-card:hover {
                border-color: var(--robot-blue);
                transform: translateY(-5px);
            }

        .icon-shape {
            width: 48px;
            height: 48px;
            background: rgba(0, 210, 255, 0.1);
            color: var(--robot-blue);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
        }

        /* DataTables Custom Dark Theme */
        .dataTables_wrapper {
            background: var(--robot-card-bg);
            padding: 20px;
            border-radius: 15px;
            color: var(--text-main);
        }

        table.dataTable {
            color: var(--text-main) !important;
            border-bottom: 1px solid var(--text-dim) !important;
        }

        .table > :not(caption) > * > * {
            background-color: transparent !important;
            color: var(--text-main);
            border-bottom-color: rgba(255,255,255,0.1);
        }

        .page-link {
            background-color: var(--robot-dark-bg);
            border-color: rgba(255,255,255,0.1);
            color: var(--robot-blue);
        }

        .dataTables_info, .dataTables_length, .dataTables_filter {
            color: var(--text-dim) !important;
            margin-bottom: 15px;
        }

        input[type="search"] {
            background-color: var(--robot-dark-bg) !important;
            border: 1px solid var(--text-dim) !important;
            color: white !important;
        }

        /* Gráficas */
        .chart-container {
            background: var(--robot-card-bg);
            border-radius: 15px;
            padding: 20px;
            margin-top: 20px;
        }

        h2 {
            font-family: 'Orbitron', sans-serif;
            color: var(--robot-blue);
            font-size: 1.5rem;
        }
    </style>
}

    <div class="row mb-4">
        <div class="col">
            <h2 class="mb-0"><i class="fas fa-robot me-2"></i>Panel de Control Robotix</h2>
            <p class="text-muted mt-2">Estado global de la academia</p>
        </div>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-6">
            <div class="stat-card d-flex align-items-center">
                <div class="icon-shape me-3"><i class="fas fa-users"></i></div>
                <div>
                    <h6 class="text-muted mb-0">Alumnos</h6>
                    <h3 class="mb-0">0</h3>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <a asp-controller="Cursos" asp-action="ListaCursos">
                <div class="stat-card d-flex align-items-center">
                    <div class="icon-shape me-3" style="color: #10b981; background: rgba(16, 185, 129, 0.1);"><i class="fas fa-graduation-cap"></i></div>
                    <div>
                        <h6 class="text-muted mb-0">Cursos Activos</h6>
                        <h3 class="mb-0">0</h3>
                    </div>
                </div>
            </a>
        </div>
