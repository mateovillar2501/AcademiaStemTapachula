@section Styles{
    <link rel="stylesheet" href="~/dashboard/css/bootstrap.min.css" />

    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700&family=Roboto:wght@300;400&display=swap" rel="stylesheet">
    <style>
        :root {
            --robot-blue: #00d2ff;
            --robot-dark-bg: #0f172a; /* Fondo profundo */
            --robot-card-bg: #1e293b; /* Fondo de tarjeta */
            --robot-accent: #f43f5e;   /* Rosa/Rojo neón */
            --text-main: #f8fafc;
            --text-dim: #94a3b8;
        }

        h1 {
            font-family: 'Orbitron', sans-serif;
            color: var(--robot-blue);
            text-transform: uppercase;
            letter-spacing: 2px;
            text-shadow: 0 0 10px rgba(0, 210, 255, 0.3);
        }

        /* Estilos de la Tarjeta */
        .card-robot {
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 15px;
            overflow: hidden;
            transition: all 0.3s ease;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.3);
            background: var(--robot-card-bg);
        }

        .card-robot:hover {
            transform: translateY(-10px);
            box-shadow: 0 10px 25px rgba(0, 210, 255, 0.2);
            border-color: var(--robot-blue);
        }

        .card-img-top {
            height: 200px;
            object-fit: cover;
            transition: transform 0.5s ease;
            filter: brightness(0.8); /* Un poco más oscuro para encajar */
        }

        .card-robot:hover .card-img-top {
            transform: scale(1.1);
            filter: brightness(1);
        }

        .card-body {
            padding: 1.5rem;
        }

        .card-title {
            font-family: 'Orbitron', sans-serif;
            font-size: 1.2rem;
            color: var(--robot-blue);
        }

        .card-text {
            color: var(--text-dim) !important;
        }

        /* Botones Personalizados */
        .btn-edit {
            background-color: var(--robot-blue);
            color: #0f172a;
            font-weight: bold;
            border: none;
            transition: all 0.3s;
        }

        .btn-edit:hover {
            background-color: #7dd3fc;
            box-shadow: 0 0 15px rgba(0, 210, 255, 0.4);
            color: #0f172a;
        }

        .btn-delete {
            background-color: transparent;
            color: var(--robot-accent);
            border: 1px solid var(--robot-accent);
        }

        .btn-delete:hover {
            background-color: var(--robot-accent);
            color: white;
            box-shadow: 0 0 15px rgba(244, 63, 94, 0.4);
        }

        /* Animación de entrada */
        @@keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .course-col {
            animation: fadeIn 0.6s ease forwards;
        }
        
        .text-muted {
            color: var(--text-dim) !important;
        }
    </style>
}





    <div class="text-center mb-5">
        <h1>Cursos de Robótica</h1>
        <p class="text-muted">Gestiona el catálogo de aprendizaje tecnológico</p>
    </div>

    <div class="row g-4" id="courseContainer"></div>




        
@section Scripts{
    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>


    @*MODULO JS*@
    <script src="~/dashboard/js/App/Cursos/ListaCursos.js"></script>
}
