@*
    PANEL PARA AÑADIR UN NUEVO CURSO
*@
@{
}   
@section Styles {

    <style>
        :root {
            --robot-blue: #00d2ff;
            --robot-dark-bg: #0f172a;
            --robot-card-bg: #1e293b;
            --robot-accent: #f43f5e;
            --robot-green: #10b981;
            --text-main: #f8fafc;
            --text-dim: #94a3b8;
        }

   

        /* Barra Lateral (Nav) */
        nav.col-md-2 {
            background-color: #0b1120 !important; /* Un tono más oscuro que el fondo */
            border-right: 1px solid rgba(0, 210, 255, 0.1) !important;
        }

        nav h5 {
            font-family: 'Orbitron', sans-serif;
            color: var(--robot-blue);
            font-size: 0.9rem;
            letter-spacing: 1px;
            border-bottom: 1px solid rgba(0, 210, 255, 0.2) !important;
        }

        /* Botones de la barra lateral */
        .btn-primary {
            background-color: var(--robot-blue);
            border: none;
            color: var(--robot-dark-bg);
            font-weight: bold;
            transition: all 0.3s ease;
        }

        .btn-primary:hover {
            background-color: #7dd3fc;
            box-shadow: 0 0 15px rgba(0, 210, 255, 0.4);
            transform: translateY(-2px);
        }

        .btn-outline-light {
            border-color: var(--text-dim);
            color: var(--text-dim);
        }

        .btn-outline-light:hover {
            background-color: var(--robot-accent);
            border-color: var(--robot-accent);
            color: white;
        }

        .btn-success {
            background-color: transparent;
            border: 1px solid var(--robot-green);
            color: var(--robot-green);
            font-family: 'Orbitron', sans-serif;
            font-size: 0.8rem;
        }

        .btn-success:hover {
            background-color: var(--robot-green);
            color: var(--robot-dark-bg);
            box-shadow: 0 0 15px rgba(16, 185, 129, 0.4);
        }

        /* Editor de Código */
        #codeEditor {
            font-family: "Fira Code", Consolas, "Courier New", monospace;
            font-size: 14px;
            background-color: #050810 !important; /* Casi negro para el código */
            color: #e2e8f0;
            border: none;
            outline: none;
            padding: 20px;
            line-height: 1.6;
            tab-size: 4;
            caret-color: var(--robot-blue);
            border-radius: 0 !important;
        }

        #codeEditor::placeholder {
            color: #334155;
        }

        #codeEditor:focus {
            box-shadow: inset 0 0 10px rgba(0, 210, 255, 0.1);
        }

        /* Cabeceras de Editor y Vista Previa */
        main .bg-light, section .bg-light {
            background-color: var(--robot-card-bg) !important;
            color: var(--robot-blue) !important;
            border: none !important;
            border-bottom: 1px solid rgba(255,255,255,0.05) !important;
            border-radius: 0 !important;
        }

        .badge.bg-primary {
            background-color: rgba(0, 210, 255, 0.1) !important;
            color: var(--robot-blue) !important;
            border: 1px solid var(--robot-blue);
            font-family: 'Orbitron', sans-serif;
            font-size: 0.7rem;
        }

        /* Sección de Vista Previa */
        section.col-md-5 {
            background-color: #f8fafc !important; /* Fondo blanco para el iframe para ver bien el diseño */
            border-radius: 0 !important;
        }

        #previewFrame {
            background-color: black;
        }

        hr {
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            opacity: 1;
        }
        /* === RESET CONTROLADO PARA FORM (Bootstrap safe) === */
        form {
            margin: 0 !important;
            padding: 0 !important;
            border: 0 !important;
            background: transparent !important;
            display: block;
            width: 100%;
            box-shadow: none !important;
        }

   
    </style>

}

<div class="container-fluid vh-100 p-0">

    <form id="FormularioCodigo" class="h-100">

        <div class="row g-0 h-100">

            <!-- NAV -->
            <nav class="col-md-2 bg-dark text-white border-end p-3 d-flex flex-column shadow h-100">

                <h5 class="mb-4 border-bottom pb-2">Acciones</h5>

                <button type="submit" class="btn btn-primary mb-3 w-100" id="Guardar">
                    Ejecutar Código
                </button>

                <button type="button" class="btn btn-outline-light mb-3 w-100" onclick="clearEditor()">
                    Limpiar
                </button>

                <hr>

                <button type="button" class="btn btn-success mb-3 w-100" disabled id="Enviar">
                    AGREGAR CURSO
                </button>

            </nav>

            <!-- EDITOR -->
            <main class="col-md-5 d-flex flex-column border-end h-100">

                <div class="bg-light p-2 rounded-3 d-flex border-white justify-content-between align-items-center"> <span class="fw-bold px-2">Editor de Código</span> <span class="badge bg-primary text-dark">HTML / CSS</span> </div> 
                <textarea id="codeEditor" class="form-control rounded-3 flex-grow-1 border-0 font-monospace p-3" placeholder="Escribe o pega tu código aquí..." style="resize: none; background-color: #000110;"></textarea>

            </main>

            <!-- PREVIEW -->
            <section class="col-md-5 d-flex flex-column bg-secondary h-100">

                <div class="bg-light p-2 border-bottom">
                    <span class="badge bg-primary text-dark">Vista Previa</span>
                </div>

                <iframe id="previewFrame" class="w-100 flex-grow-1 border-0 "></iframe>

            </section>

        </div>

    </form>

</div>


    
@section Scripts {


    <script src="~/dashboard/js/App/Cursos/AgregarCurso.js"></script>


}