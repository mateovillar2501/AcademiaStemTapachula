@*
    PANEL PARA AÑADIR UN NUEVO CURSO
*@
@{
}   
@section Styles {
<style>

 

    /* Editor estilo VS Code */
    #codeEditor {
        font-family: "Fira Code", Consolas, monospace;
        font-size: 14px;
        background-color: #0d1117;
        color: #e6edf3;
        border: none;
        outline: none;
        padding: 15px;
        line-height: 1.5;
        tab-size: 4;
        caret-color: #58a6ff;
    }

    #codeEditor::placeholder{
        color:#6e7681;
    }

    #codeEditor:focus{
        box-shadow: inset 0 0 0 1px #58a6ff;
    }

</style>
}
<div class="container-fluid vh-100 d-flex flex-column p-0">
    <div class="row g-0 flex-grow-1">
        
        <nav class="col-md-2 bg-dark text-white border-end p-3 d-flex flex-column shadow">
            <h5 class="mb-4 border-bottom pb-2">Acciones</h5>
            <button class="btn btn-primary mb-3 w-100" onclick="renderCode()">
                <i class="bi bi-play-fill"></i> Ejecutar Código
            </button>
            <button class="btn btn-outline-light mb-3 w-100" onclick="clearEditor()">
                <i class="bi bi-trash"></i> Limpiar
            </button>
            <hr>
            <button class="btn btn-success mb-3 w-100" onclick="renderCode()">
                <i class="bi bi-play-fill"></i> AGREGAR CURSO
            </button>
            

        </nav>

        <main class="col-md-5 d-flex flex-column border-end ">
            <div class="bg-light p-2 rounded-3 d-flex border-white justify-content-between align-items-center">
                <span class="fw-bold px-2">Editor de Código</span>
                <span class="badge bg-primary text-dark">HTML / CSS</span>
            </div>
            <textarea id="codeEditor" class="form-control rounded-3 flex-grow-1 border-0 font-monospace p-3"
                      placeholder="Escribe o pega tu código aquí..."
                      style="resize: none; background-color: #000110;"></textarea>
        </main>

        <section class="col-md-5 d-flex flex-column bg-secondary rounded-3">
            <div class="bg-light p-2 border-bottom rounded-3">
                <span class="badge fw-bold px-2 bg-primary text-dark">Vista Previa</span>
            </div>
            <iframe id="previewFrame" class="w-100 h-100 border-0 shadow-sm"></iframe>
        </section>
    </div>
</div>



@section Scripts {

    <script>

        function renderCode() {

            const code = document.getElementById("codeEditor").value;
            const frame = document.getElementById("previewFrame");

            const doc = frame.contentDocument || frame.contentWindow.document;

            doc.open();
            doc.write(code);
            doc.close();
        }

        function clearEditor() {

             location.reload();
        }


        /* Permitir TAB dentro del textarea como editor real */

        document.getElementById("codeEditor").addEventListener("keydown", function(e) {

            if (e.key === "Tab") {
                e.preventDefault();

                let start = this.selectionStart;
                let end = this.selectionEnd;

                this.value = this.value.substring(0, start)
                    + "\t"
                    + this.value.substring(end);

                this.selectionStart = this.selectionEnd = start + 1;
            }

        });

    </script>

}